# ── Anthropic API (required) ─────────────────────────────────────────
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model tiers (defaults shown; agent = reasoning, utility = memory extraction + eval judge)
CALENDAI_AGENT_MODEL=claude-sonnet-4-6
CALENDAI_UTILITY_MODEL=claude-haiku-4-5

# ── Storage ──────────────────────────────────────────────────────────
CALENDAI_DB_PATH=data/calendai.db

# ── Google OAuth (required for live calendar; NOT needed for tests/evals) ──
# Cloud Console -> APIs & Services -> Credentials -> OAuth client (Web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Fernet key for encrypting OAuth tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CALENDAI_FERNET_KEY=

# ── Server ───────────────────────────────────────────────────────────
CALENDAI_BASE_URL=http://localhost:8000
